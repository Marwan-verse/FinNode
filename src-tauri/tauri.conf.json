{
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run build:web",
    "devPath": "../dist",
    "distDir": "../dist"
  },
  "package": {
    "productName": "FinNode",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.marwanverse.finnode",
      "icon": ["icons/icon.ico", "icons/icon.png"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "FinNode",
        "width": 1440,
        "height": 900,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": true,
        "center": true
      }
    ]
  }
}
